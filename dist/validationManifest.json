  "standards": [
    {
      "id": "ieee1584",
      "name": "IEEE 1584-2018",
      "title": "Guide for Performing Arc-Flash Hazard Calculations",
      "studyPage": "arcFlash.html",
      "scope": "Arc flash incident energy and protection boundary for AC equipment 208 V – 15 kV",
      "assumptions": [
        "Arcing faults modeled as bolted fault with empirical reduction factor",
        "Incident energy assumes person at working distance perpendicular to the arc",
        "Three-phase balanced system; unbalanced faults not covered"
      ],
      "limitations": [
        "Validated for 208 V to 15 kV; extrapolation outside this range is not supported",
        "Does not cover DC arc flash (use NFPA 70E Annex D.8 or IEC 62271)"
      ]
    },
    {
      "id": "iec60909",
      "name": "IEC 60909-0:2016",
      "title": "Short-circuit currents in three-phase AC systems — Calculation of currents",
      "studyPage": "iec60909.html",
      "scope": "Maximum and minimum short-circuit currents for three-phase AC systems up to 550 kV",
      "assumptions": [
        "Equivalent voltage source method (no pre-fault load currents in calculation)",
        "Voltage factor c applied to nominal voltage (1.0–1.1 for max; 0.95 for min)",
        "Far-from-generator condition unless generator correction factor K_G is applied"
      ],
      "limitations": [
        "Near-to-generator μ factor (Ib reduction) not yet implemented",
        "Transformer correction factor K_T exported but not batch-applied per transformer",
        "Generator correction factor K_G not implemented"
      ]
    },
    {
      "id": "iec60287",
      "name": "IEC 60287-1-1:2023",
      "title": "Electric cables — Calculation of the current rating",
      "studyPage": "iec60287.html",
      "scope": "Continuous current ratings for cables in direct burial, conduit, trays, and free air",
      "assumptions": [
        "100% load factor (continuous steady-state rating)",
        "Uniform soil temperature and resistivity along cable route",
        "Cables in trefoil or flat formation (no transposition modeled)"
      ],
      "limitations": [
        "Cyclic/daily load profiles not yet supported (use IEC 60287-2-2 method)",
        "Soil drying-out (critical isotherm) model not implemented",
        "Cable crossings and mutual heating from parallel routes require manual input"
      ]
    },
    {
      "id": "ieee80",
      "name": "IEEE 80-2013",
      "title": "Guide for Safety in AC Substation Grounding",
      "studyPage": "groundgrid.html",
      "scope": "Rectangular ground grid design: mesh voltage, step voltage, grid resistance",
      "assumptions": [
        "Uniform soil resistivity (single-layer model)",
        "Rectangular grid geometry; irregular shapes require mesh-boundary approximation",
        "Touch/step voltage limits from IEEE 80 Table 7 (heart-current factor K_h = 1.0)"
      ],
      "limitations": [
        "Two-layer soil model not yet implemented (use SES CDEGS for multi-layer analysis)",
        "Irregular electrode geometry (L-shaped grids, remote ground rods) approximated",
        "Transferred voltage check not automated"
      ]
    },
